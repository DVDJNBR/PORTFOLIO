---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  href={project.url}
  target="_blank"
  rel="noopener noreferrer"
  class="card"
>
  {project.image && (
    <div class="card-image-wrapper">
      <img src={project.image} alt={project.title} class="card-image" loading="lazy" />
    </div>
  )}
  <div class="card-content">
    <div class="card-header">
      <h2 class="card-title">{project.title}</h2>
      {project.briefNumber && <span class="brief-badge">Brief #{project.briefNumber}</span>}
    </div>
    <p class="card-desc">{project.description}</p>
    <div class="tags">
      {project.tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>
  <span class="card-arrow">→</span>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: space-between;
    gap: 1rem;
    padding: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
    overflow: hidden;
  }

  .card-image-wrapper {
    width: 100%;
    height: 160px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card:hover .card-image {
    transform: scale(1.05);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(96, 165, 250, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
    pointer-events: none;
  }

  html.dark .card::before {
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.15) 0%, rgba(147, 197, 253, 0.05) 100%);
  }

  .card:hover {
    box-shadow: 0 10px 30px -10px var(--accent);
    transform: translateY(-5px) scale(1.02);
    border-color: var(--accent);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    padding: 1.25rem 1.5rem;
  }

  .card:hover .card-title {
    color: var(--accent);
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .card-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--fg);
  }
  .brief-badge {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-weight: 500;
  }
  .card-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.5;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--tag-bg);
    color: var(--tag-fg);
    border: 1px solid var(--border);
  }
  .card-arrow {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    color: var(--fg-muted);
    font-size: 1.2rem;
    flex-shrink: 0;
    transition: transform 0.2s, color 0.2s;
  }
  .card:hover .card-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }
</style>
