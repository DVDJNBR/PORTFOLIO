---
interface Props {
  title?: string;
}
const { title = 'dvdjnbr — Portfolio' } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Anti-flash: applique le thème avant le premier rendu -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        } else if (saved === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <style is:global>
      :root {
        --bg: #f8f9fa;
        --fg: #1a1a1a;
        --fg-muted: #555;
        --surface: #ffffff;
        --border: #e0e0e0;
        --accent: #3b82f6;
        --shadow: rgba(0, 0, 0, 0.08);
        --tag-bg: #f0f4ff;
        --tag-fg: #1e40af;
      }

      @media (prefers-color-scheme: dark) {
        :root:not(.light) {
          --bg: #111214;
          --fg: #e8e8e8;
          --fg-muted: #888;
          --surface: #1c1e21;
          --border: #2e3035;
          --accent: #60a5fa;
          --shadow: rgba(0, 0, 0, 0.4);
          --tag-bg: #1e2a42;
          --tag-fg: #93c5fd;
        }
      }

      html.dark {
        --bg: #111214;
        --fg: #e8e8e8;
        --fg-muted: #888;
        --surface: #1c1e21;
        --border: #2e3035;
        --accent: #60a5fa;
        --shadow: rgba(0, 0, 0, 0.4);
        --tag-bg: #1e2a42;
        --tag-fg: #93c5fd;
      }

      html.light {
        --bg: #f8f9fa;
        --fg: #1a1a1a;
        --fg-muted: #555;
        --surface: #ffffff;
        --border: #e0e0e0;
        --accent: #3b82f6;
        --shadow: rgba(0, 0, 0, 0.08);
        --tag-bg: #f0f4ff;
        --tag-fg: #1e40af;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        min-height: 100vh;
        transition: background 0.2s, color 0.2s;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
