---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { projects } from '../data/projects';
---

<Layout>
  <div class="page">
    <header class="header">
      <div class="header-inner">
        <span class="site-name">David Breau</span>
        <ThemeToggle />
      </div>
    </header>

    <main class="main">
      <section class="hero">
        <h1 class="hero-name">David Breau</h1>
        <p class="hero-tagline">À venir</p>
        <div class="social-links">
          <a href="https://www.linkedin.com/in/david-breau" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://x.com/d4v1dbr34u" target="_blank" rel="noopener noreferrer">Twitter</a>
        </div>
      </section>

      <section class="projects">
        <h2 class="section-title">Projets</h2>

        <div class="carousel-container">
          <button class="carousel-btn prev-btn" aria-label="Projet précédent">‹</button>

          <div class="carousel-viewport">
            <div class="project-list">
              {projects.map((project, i) => (
                <div class="project-slide" data-index={i}>
                  <ProjectCard project={project} />
                </div>
              ))}
            </div>
          </div>

          <button class="carousel-btn next-btn" aria-label="Projet suivant">›</button>
        </div>

        <div class="carousel-indicators">
          {/* Les indicateurs < o 0 O 0 o > seront générés par JS selon le nombre de projets */}
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .header {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .site-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg-muted);
    letter-spacing: 0.01em;
  }

  .hero {
    margin-bottom: 3.5rem;
  }
  .hero-name {
    margin: 0 0 0.4rem;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .hero-tagline {
    margin: 0 0 1rem;
    font-size: 1.05rem;
    color: var(--fg-muted);
  }
  .social-links {
    display: flex;
    gap: 1rem;
  }
  .social-links a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .social-links a:hover {
    text-decoration: underline;
  }

  .section-title {
    margin: 0 0 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }

  .carousel-container {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .carousel-viewport {
    overflow: hidden;
    width: 100%;
    border-radius: 10px;
    padding: 2rem 0;
    margin: -2rem 0;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .project-list {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    align-items: center;
    will-change: transform;
  }

  .project-slide {
    flex: 0 0 75%;
    min-width: 75%;
    padding: 1rem;
    box-sizing: border-box;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.2;
    transform: scale(0.7);
    filter: blur(4px);
    pointer-events: none;
  }

  .project-slide.is-active {
    opacity: 1;
    transform: scale(1.05);
    filter: blur(0);
    z-index: 10;
    pointer-events: auto;
  }

  .project-slide.is-near {
    opacity: 0.6;
    transform: scale(0.85);
    filter: blur(1px);
    z-index: 5;
    pointer-events: auto;
  }

  .carousel-btn {
    background: var(--surface);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s, transform 0.2s;
    z-index: 10;
  }

  .carousel-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: scale(1.1);
  }

  .carousel-indicators {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    user-select: none;
  }

  .indicator-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .indicator-dot:hover {
    background: var(--fg-muted);
    transform: scale(1.2);
  }

  .indicator-dot.active {
    background: var(--accent);
    transform: scale(1.3);
    box-shadow: 0 0 10px var(--accent);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector('.project-list') as HTMLElement;
    const slides = Array.from(document.querySelectorAll('.project-slide')) as HTMLElement[];
    const prevBtn = document.querySelector('.prev-btn') as HTMLButtonElement;
    const nextBtn = document.querySelector('.next-btn') as HTMLButtonElement;
    const indicatorsContainer = document.querySelector('.carousel-indicators') as HTMLElement;

    if (!track || slides.length === 0) return;

    let currentIndex = 0;

    const updateCarousel = () => {
      const slideWidth = slides[0].offsetWidth;
      const viewportWidth = track.parentElement?.offsetWidth || 0;

      // Calculate the position to center the current slide
      const offset = (viewportWidth / 2) - (slideWidth / 2) - (currentIndex * slideWidth);

      track.style.transform = `translateX(${offset}px)`;

      // Update slide classes
      slides.forEach((slide, index) => {
        const distance = Math.abs(index - currentIndex);
        slide.classList.remove('is-active', 'is-near');

        if (distance === 0) {
          slide.classList.add('is-active');
        } else if (distance === 1) {
          slide.classList.add('is-near');
        }
      });

      // Update indicators
      renderIndicators();
    };

    const renderIndicators = () => {
      indicatorsContainer.replaceChildren();

      slides.forEach((_, index) => {
        const dot = document.createElement('div');
        dot.className = `indicator-dot ${index === currentIndex ? 'active' : ''}`;

        dot.addEventListener('click', () => {
          currentIndex = index;
          updateCarousel();
        });

        indicatorsContainer.appendChild(dot);
      });

      indicatorsContainer.appendChild(fragment);
    };

    prevBtn.addEventListener('click', () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel();
      }
    });

    nextBtn.addEventListener('click', () => {
      if (currentIndex < slides.length - 1) {
        currentIndex++;
        updateCarousel();
      }
    });

    // Initialize
    updateCarousel();

    // Re-calculate on resize
    window.addEventListener('resize', updateCarousel);
  });
</script>
