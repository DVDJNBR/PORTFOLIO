---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { projects } from '../data/projects';
---

<Layout>
  <div class="page">
    <header class="header">
      <div class="header-inner">
        <span class="site-name">David Breau</span>
        <ThemeToggle />
      </div>
    </header>

    <main class="main">
      <section class="hero">
        <h1 class="hero-name">David Breau</h1>
        <p class="hero-tagline">À venir</p>
        <div class="social-links">
          <a href="https://www.linkedin.com/in/david-breau" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://x.com/d4v1dbr34u" target="_blank" rel="noopener noreferrer">Twitter</a>
        </div>
      </section>

      <section class="projects">
        <h2 class="section-title">Projets</h2>

        <div class="carousel-container">
          <button class="carousel-btn prev-btn" aria-label="Projet précédent">‹</button>

          <div class="carousel-viewport">
            <div class="project-list">
              {projects.map((project, i) => (
                <div class="project-slide" data-index={i}>
                  <ProjectCard project={project} />
                </div>
              ))}
            </div>
          </div>

          <button class="carousel-btn next-btn" aria-label="Projet suivant">›</button>
        </div>

        <div class="carousel-indicators">
          {/* Les indicateurs < o 0 O 0 o > seront générés par JS selon le nombre de projets */}
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .header {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .site-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg-muted);
    letter-spacing: 0.01em;
  }

  .hero {
    margin-bottom: 3.5rem;
  }
  .hero-name {
    margin: 0 0 0.4rem;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .hero-tagline {
    margin: 0 0 1rem;
    font-size: 1.05rem;
    color: var(--fg-muted);
  }
  .social-links {
    display: flex;
    gap: 1rem;
  }
  .social-links a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .social-links a:hover {
    text-decoration: underline;
  }

  .section-title {
    margin: 0 0 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }

  .carousel-container {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .carousel-viewport {
    overflow: hidden;
    width: 100%;
    border-radius: 10px;
  }

  .project-list {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    /* Set width in JS or manage flex-shrink */
  }

  .project-slide {
    flex: 0 0 100%;
    min-width: 100%;
    padding: 0.5rem; /* Add some padding so hover effect doesn't get clipped easily */
    box-sizing: border-box;
    transition: opacity 0.3s, transform 0.3s;
    opacity: 0.5;
    transform: scale(0.95);
  }

  .project-slide.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .carousel-btn {
    background: var(--surface);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s, transform 0.2s;
    z-index: 10;
  }

  .carousel-btn:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: scale(1.1);
  }

  .carousel-indicators {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    font-family: monospace;
    font-size: 1.2rem;
    color: var(--fg-muted);
    user-select: none;
  }

  .indicator {
    cursor: pointer;
    transition: color 0.2s, transform 0.2s;
    display: inline-block;
  }

  .indicator:hover {
    color: var(--fg);
  }

  .indicator.active {
    color: var(--accent);
    font-weight: bold;
    transform: scale(1.2);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector('.project-list') as HTMLElement;
    const slides = Array.from(document.querySelectorAll('.project-slide')) as HTMLElement[];
    const prevBtn = document.querySelector('.prev-btn') as HTMLButtonElement;
    const nextBtn = document.querySelector('.next-btn') as HTMLButtonElement;
    const indicatorsContainer = document.querySelector('.carousel-indicators') as HTMLElement;

    if (!track || slides.length === 0) return;

    let currentIndex = 0;

    // Sort logic wasn't needed as user asked for most recent by default, assuming order array is already correct
    // But let's build the indicators: < o 0 O 0 o > pattern
    // If 1 item: O
    // If 2 items: O 0
    // If 3 items: o O o
    // In our case we just update indicators text based on distance to active

    const updateCarousel = () => {
      // Move track
      track.style.transform = `translateX(-${currentIndex * 100}%)`;

      // Update slide classes
      slides.forEach((slide, index) => {
        if (index === currentIndex) {
          slide.classList.add('is-active');
        } else {
          slide.classList.remove('is-active');
        }
      });

      // Update indicators
      renderIndicators();
    };

    const renderIndicators = () => {
      indicatorsContainer.innerHTML = '';

      // Custom pattern: < o 0 O 0 o > (as asked: o smaller, 0 bigger, O highlighted)
      slides.forEach((_, index) => {
        const span = document.createElement('span');
        span.className = 'indicator';

        let char = 'o';
        const distance = Math.abs(index - currentIndex);

        if (distance === 0) {
          char = 'O';
          span.classList.add('active');
        } else if (distance === 1) {
          char = '0';
        } else {
          char = 'o';
        }

        span.textContent = char;
        span.addEventListener('click', () => {
          currentIndex = index;
          updateCarousel();
        });

        indicatorsContainer.appendChild(span);
      });
    };

    prevBtn.addEventListener('click', () => {
      if (currentIndex > 0) {
        currentIndex--;
        updateCarousel();
      }
    });

    nextBtn.addEventListener('click', () => {
      if (currentIndex < slides.length - 1) {
        currentIndex++;
        updateCarousel();
      }
    });

    // Initialize
    updateCarousel();
  });
</script>
